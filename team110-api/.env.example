# Local dev: run Cloud SQL Auth Proxy, then point DB_HOST / DB_PORT at the proxy.
#   cloud-sql-proxy root-matrix-441506-r9:us-central1:db-sp26-team110 --port 3307
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=app_user
DB_PASSWORD=your-password
DB_NAME=team110_db

# Cloud Run: set these instead of DB_HOST/DB_PORT
# CLOUD_SQL_CONNECTION_NAME=root-matrix-441506-r9:us-central1:db-sp26-team110

# Optional: custom SQL (use \n for newlines in .env or set in Cloud Run env)
# COURSES_SQL=SELECT course_id AS id, ...
